{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug STM32F407",
            "type": "cortex-debug", 
            "request": "launch",
            "breakAfterReset": true,
            "servertype": "stlink",
            "cwd": "${workspaceRoot}",
            // 1. MAKE SURE THIS POINTS TO YOUR ACTUAL COMPILED .elf OR .hex FILE
            "executable": "${workspaceRoot}/Build_sys/ARM_M4_BM_DEV.elf", 
            "device": "STM32F407VGT6",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "runToEntryPoint": "main"
        }
    ]
}